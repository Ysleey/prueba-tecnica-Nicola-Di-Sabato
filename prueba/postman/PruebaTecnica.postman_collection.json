{
  "info": {
    "name": "Prueba Tecnica CRUD - Productos",
    "description": "Coleccion para validar funcionalidad, errores y contrato HTTP del backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "productId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Crear producto (201)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Teclado\",\n  \"description\": \"Mecanico\",\n  \"price\": 99.90,\n  \"stock\": 8\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "var body = pm.response.json();",
              "pm.test('Tiene id', function () { pm.expect(body.id).to.exist; });",
              "pm.collectionVariables.set('productId', String(body.id));",
              "if (pm.environment) { pm.environment.set('productId', String(body.id)); }"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Listar productos (200)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products?page=0&size=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var body = pm.response.json();",
              "pm.test('Trae estructura paginada', function () {",
              "  pm.expect(body).to.have.property('content');",
              "  pm.expect(body).to.have.property('page');",
              "  pm.expect(body).to.have.property('size');",
              "  pm.expect(body).to.have.property('totalElements');",
              "  pm.expect(body).to.have.property('totalPages');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Obtener por id (200)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var body = pm.response.json();",
              "pm.test('El id coincide', function () { pm.expect(String(body.id)).to.eql(String(pm.collectionVariables.get('productId'))); });"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Actualizar producto (200)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Teclado Pro\",\n  \"description\": \"Mecanico RGB\",\n  \"price\": 109.90,\n  \"stock\": 10\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "var body = pm.response.json();",
              "pm.test('Nombre actualizado', function () { pm.expect(body.name).to.eql('Teclado Pro'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Eliminar producto (204)",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 204', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    },
    {
      "name": "06 - Obtener eliminado (404)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{productId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404', function () { pm.response.to.have.status(404); });",
              "var body = pm.response.json();",
              "pm.test('Mensaje de not found', function () { pm.expect(body.message).to.include('no encontrado'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "07 - Validacion body invalido (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"description\": \"X\",\n  \"price\": 0,\n  \"stock\": -1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
              "var body = pm.response.json();",
              "pm.test('Mensaje validacion', function () { pm.expect(body.message).to.eql('Error de validacion'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "08 - JSON mal formado (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"name\": \"Mouse\", \"price\": }"
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
              "var body = pm.response.json();",
              "pm.test('Mensaje JSON invalido', function () { pm.expect(body.message).to.eql('Body JSON invalido'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "09 - Id con tipo invalido (400)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products/abc",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "abc"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
              "var body = pm.response.json();",
              "pm.test('Mensaje de formato invalido', function () { pm.expect(body.message).to.eql('El parametro id tiene un formato invalido'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "10 - Paginacion invalida (400)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products?page=0&size=0",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "0"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 400', function () { pm.response.to.have.status(400); });",
              "var body = pm.response.json();",
              "pm.test('Mensaje size invalido', function () { pm.expect(body.message).to.eql('size debe ser > 0'); });"
            ]
          }
        }
      ]
    }
  ]
}
